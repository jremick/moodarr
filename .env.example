# Moodarr defaults to fixture mode when Plex and Seerr credentials are absent.
# Set MOODARR_FIXTURE_MODE=false when you want missing integrations to fail loudly.
# MOODARR_FIXTURE_MODE=true
MOODARR_DATA_DIR=.data
MOODARR_CONFIG_PATH=.data/config.json
MOODARR_DB_PATH=.data/moodarr.sqlite
MOODARR_API_PORT=4401
MOODARR_API_HOST=127.0.0.1
MOODARR_WEB_ORIGIN=http://127.0.0.1:5173
MOODARR_SERVE_CLIENT=false

# Admin protection. For containers, set REQUIRE=true and provide a long random token.
MOODARR_REQUIRE_ADMIN_TOKEN=false
# MOODARR_ADMIN_AUTH_REQUIRED=false
MOODARR_ADMIN_TOKEN=
# Explicit opt-in LAN convenience. Keep false when Plex users or untrusted LAN clients can reach Moodarr.
MOODARR_ADMIN_AUTO_SESSION=false
MOODARR_SYNC_INTERVAL_MINUTES=360
MOODARR_SYNC_SEERR=true
MOODARR_DEFAULT_RESULT_LIMIT=50

# Plex read-only integration. Keep the token server-side.
PLEX_BASE_URL=http://127.0.0.1:32400
PLEX_TOKEN=
PLEX_WEB_BASE_URL=https://app.plex.tv/desktop

# Optional Plex sign-in for non-admin Finder access.
MOODARR_PLEX_AUTH_ENABLED=false
MOODARR_PLEX_AUTH_ALLOW_NEW_USERS=true
# MOODARR_PLEX_AUTH_CLIENT_ID=
# MOODARR_PLEX_AUTH_PRODUCT_NAME=Moodarr

# Seerr, Jellyseerr, or Overseerr-compatible API integration.
SEERR_BASE_URL=http://127.0.0.1:5055
SEERR_API_KEY=

# Source/EXP development only. The v0.1.0-beta.1 release image bakes in a
# non-overridable local-only provider policy and ignores these values.
AI_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
