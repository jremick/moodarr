# Feelerr defaults to fixture mode when Plex and Seerr credentials are absent.
FEELERR_FIXTURE_MODE=true
FEELERR_DB_PATH=.data/feelerr.sqlite
FEELERR_API_PORT=4401
FEELERR_WEB_ORIGIN=http://127.0.0.1:5173

# Plex read-only integration. Keep the token server-side.
PLEX_BASE_URL=http://127.0.0.1:32400
PLEX_TOKEN=
PLEX_WEB_BASE_URL=https://app.plex.tv/desktop

# Seerr, Jellyseerr, or Overseerr-compatible API integration.
SEERR_BASE_URL=http://127.0.0.1:5055
SEERR_API_KEY=

# Optional server-side AI reranking/explanations.
AI_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
