# Feelarr defaults to fixture mode when Plex and Seerr credentials are absent.
# Set FEELERR_FIXTURE_MODE=false when you want missing integrations to fail loudly.
# FEELERR_FIXTURE_MODE=true
FEELERR_DATA_DIR=.data
FEELERR_CONFIG_PATH=.data/config.json
FEELERR_DB_PATH=.data/feelerr.sqlite
FEELERR_API_PORT=4401
FEELERR_API_HOST=127.0.0.1
FEELERR_WEB_ORIGIN=http://127.0.0.1:5173
FEELERR_SERVE_CLIENT=false

# Admin protection. For containers, set REQUIRE=true and provide a long random token.
FEELERR_REQUIRE_ADMIN_TOKEN=false
# FEELERR_ADMIN_AUTH_REQUIRED=false
FEELERR_ADMIN_TOKEN=
FEELERR_SYNC_INTERVAL_MINUTES=360
FEELERR_SYNC_SEERR=true

# Plex read-only integration. Keep the token server-side.
PLEX_BASE_URL=http://127.0.0.1:32400
PLEX_TOKEN=
PLEX_WEB_BASE_URL=https://app.plex.tv/desktop

# Seerr, Jellyseerr, or Overseerr-compatible API integration.
SEERR_BASE_URL=http://127.0.0.1:5055
SEERR_API_KEY=

# Optional server-side AI reranking/explanations.
AI_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
