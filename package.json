{
  "name": "moodarr",
  "version": "0.1.0-alpha.17",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Open-source Plex + Seerr companion app for natural-language media discovery and explicit media requests.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "start": "tsx src/server/index.ts",
    "start:container": "node dist/server/index.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "vite build --config vite.server.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "eval:recommendations": "tsx scripts/evaluate-recommendations.ts",
    "eval:catalog-readiness": "tsx scripts/evaluate-catalog-readiness.ts",
    "bench:catalog-search": "tsx scripts/benchmark-catalog-search.ts",
    "eval:catalog-mood": "tsx scripts/evaluate-catalog-mood-enrichment.ts",
    "eval:profile-replay": "tsx scripts/evaluate-profile-replay.ts",
    "eval:profile-journeys": "tsx scripts/evaluate-profile-journeys.ts",
    "enrich:catalog-mood": "tsx scripts/enrich-catalog-mood-features.ts",
    "rebuild:content-fingerprints": "tsx scripts/rebuild-content-fingerprints.ts",
    "backfill:features:bulk": "tsx scripts/backfill-content-fingerprints-bulk.ts --refresh-features",
    "backfill:content-fingerprints:bulk": "tsx scripts/backfill-content-fingerprints-bulk.ts",
    "harvest:wikidata-catalog": "tsx scripts/harvest-wikidata-catalog.ts",
    "import:mood-seeds": "tsx scripts/import-mood-seeds.ts",
    "import:wikidata-catalog": "tsx scripts/import-wikidata-catalog.ts",
    "import:movielens-tag-genome": "tsx scripts/import-movielens-tag-genome.ts",
    "validate:movielens-tag-genome": "tsx scripts/validate-movielens-tag-genome.ts",
    "verify:secrets": "tsx scripts/verify-secrets.ts",
    "verify:secrets:ci": "MOODARR_SECRETS_REQUIRE_BUILD=true tsx scripts/verify-secrets.ts",
    "test:packaging": "tsx scripts/test-packaging.ts",
    "smoke:container": "tsx scripts/smoke-container.ts",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm run verify:secrets",
    "verify:release": "npm run verify && npm run eval:recommendations && npm run test:packaging && npm run smoke:container"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^9.1.3",
    "@phosphor-icons/react": "^2.1.10",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.20.6",
    "zod": "^4.1.13"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "esbuild": "0.28.1",
    "js-yaml": "4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.1",
    "rollup": "npm:@rollup/wasm-node@^4.60.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.13"
  }
}
